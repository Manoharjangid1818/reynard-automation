{
  "name": "reynard-automation",
  "version": "1.0.0",
  "description": "Playwright automation framework for Reynard application - POM based",
  "scripts": {
    "test": "playwright test",
    "test:auth": "playwright test tests/auth.spec.js --project=chromium",
    "test:personnel": "playwright test tests/personnel.spec.js",
    "test:certificates": "playwright test tests/certificates.spec.js",
    "test:training": "playwright test tests/trainingMatrix.spec.js",
    "test:settings": "playwright test tests/settings.spec.js",
    "test:projects": "playwright test tests/projectManagement.spec.js",
    "test:project-setup": "playwright test tests/projectSetup.spec.js",
    "test:application": "playwright test tests/auth.spec.js --grep \"AUTH_TC_019|AUTH_TC_020\"",
    "test:navigation": "playwright test tests/settings.spec.js tests/projectManagement.spec.js tests/qhseManagement.spec.js --grep \"SET_TC_035|SET_TC_036|PM_TC_027|SET_TC_037|PM_TC_028|PM_TC_029|PM_TC_030|PM_TC_031|PM_TC_032|PM_TC_033|QHSE_TC_013|QHSE_TC_014\"",
    "test:sync": "playwright test tests/settings.spec.js --grep \"SET_TC_038|SET_TC_039|SET_TC_040\"",
    "test:equipment": "playwright test tests/equipmentManagement.spec.js",
    "test:licenses": "playwright test tests/licenseApproval.spec.js",
    "test:qhse": "playwright test tests/qhseManagement.spec.js",
    "test:feedback": "playwright test tests/feedback.spec.js",
    "test:common": "playwright test tests/auth.spec.js tests/personnel.spec.js tests/settings.spec.js tests/projectSetup.spec.js --grep \"PERS_TC_012|PERS_TC_013|PERS_TC_014|SET_TC_041|AUTH_TC_021|AUTH_TC_022|AUTH_TC_023|SET_TC_042|AUTH_TC_024|PS_TC_001|PS_TC_002|PERS_TC_015|SET_TC_043\"",
    "test:all": "playwright test --reporter=html,json",
    "test:headed": "playwright test --headed",
    "test:auth:headed": "playwright test tests/auth.spec.js --project=chromium --headed",
    "test:auth:chromium": "playwright test tests/auth.spec.js --project=chromium",
    "test:auth:headed:chromium": "playwright test tests/auth.spec.js --project=chromium --headed",
    "test:auth:headed:firefox": "playwright test tests/auth.spec.js --project=firefox --headed",
    "report": "playwright show-report reports/html"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "fs-extra": "^11.2.0"
  }
}
