      "action": "sanity_console_clean",
      "sourceSheet": "Sanity Check",
      "automationStatus": "Yes",
      "tags": [
        "sanity"
      ],
      "path": "/authentication/sign-in",
      "expectedTexts": [
        "Log In"
      ]
    },
    {
      "id": "AUTH_TC_021",
      "title": "Verify Error messages.",
      "enabled": true,
      "action": "sanity_invalid_login_error",
      "sourceSheet": "Sanity Check",
      "automationStatus": "Yes",
      "tags": [
        "sanity"
      ],
      "email": "wrong@example.com",
      "password": "WrongPassword123"
